{
  "name": "cloudini",
  "version": "0.0.0",
  "private": true,
  "description": "Write code. Summon a serverless app.",
  "keywords": [
    "serverless",
    "infrastructure",
    "framework",
    "cli"
  ],
  "homepage": "https://github.com/Deasilsoft/cloudini",
  "bugs": {
    "url": "https://github.com/Deasilsoft/cloudini/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Deasilsoft/cloudini.git"
  },
  "license": "MIT",
  "author": "Deasilsoft <contact@deasilsoft.com>",
  "type": "module",
  "workspaces": [
    "cli",
    "framework",
    "web"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "clean": "npm run clean:install && npm run clean:workspaces",
    "preclean:install": "rm -rf node_modules package-lock.json",
    "clean:install": "npm install",
    "clean:workspaces": "npm run clean --workspaces --if-present",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "lint": "npm run lint --workspaces",
    "lint:fix": "npm run lint:fix --workspaces",
    "typecheck": "npm run typecheck --workspaces"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.3.0",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "prettier-plugin-packagejson": "^3.0.2",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.3"
  },
  "engines": {
    "node": ">=24 <25"
  }
}
